config {
  type: "view",
  name: "grant_tickets",
  description: "Main view for the grant helpdesk dashboard. Status priority: (1) manual override from ticket_metadata, (2) team_commented → answered, (3) team_reacted → in_progress, (4) open."
}

SELECT
  c.content_id,
  c.content_type,
  c.space_id,
  c.title,
  c.body,
  c.permalink,
  c.created_at,
  c.updated_at,
  c.last_activity_at,

  -- member fields
  m.member_id,
  m.full_name          AS member_name,
  m.first_name,
  m.last_name,
  m.email_address,
  m.state              AS member_state,
  m.city               AS member_city,
  m.avatar_url,
  m.join_date,
  m.last_visited_network,
  m.member_permalink,

  -- team engagement signals (failsafe)
  COALESCE(te.team_commented, FALSE)   AS team_commented,
  COALESCE(te.team_reacted,   FALSE)   AS team_reacted,
  te.first_engagement_at,

  -- final ticket status:
  -- (1) team engaged (commented or reacted) → answered, cannot be overridden
  -- (2) manual status set in Streamlit → use it (e.g. in_progress to claim a ticket)
  -- (3) nothing → open
  CASE
    WHEN te.team_commented = TRUE OR te.team_reacted = TRUE     THEN 'answered'
    WHEN t.status IS NOT NULL                                   THEN t.status
    ELSE                                                             'open'
  END                                  AS ticket_status,

  t.status                             AS manual_status,
  t.assigned_to,
  t.updated_at                         AS ticket_updated_at,

  -- AI-derived labels; manual values in ticket_metadata take precedence
  COALESCE(t.difficulty, ai.difficulty) AS difficulty,
  COALESCE(t.domain,     ai.domain)     AS domain

FROM ${ref("grant_content")} c

LEFT JOIN ${ref("stg_grant_members")} m
  ON c.member_id = m.member_id

LEFT JOIN ${ref("stg_team_engagement")} te
  ON c.content_id = te.content_id

LEFT JOIN ${ref("ticket_metadata")} t
  ON c.content_id = t.content_id

LEFT JOIN ${ref("grant_ticket_labels")} ai
  ON c.content_id = ai.content_id
