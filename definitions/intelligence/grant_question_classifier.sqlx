config {
  type: "incremental",
  schema: "grant_helpdesk",
  name: "grant_question_classifier",
  uniqueKey: ["content_id"],
  description: "Incremental LLM classification of all member content using AI.GENERATE_BOOL. Flags genuine grant-related questions. Already-classified rows are skipped on each run."
}

SELECT
  content_id,
  content_type,

  AI.GENERATE_BOOL(
    (
      'You are a classifier for a grant and financial support community helpdesk. '
      'Return TRUE if this member content expresses ANY of the following — even if vague, emotional, or not phrased as a direct question: '
      'a need for financial help, housing, rent, utilities, food, medical care, car repair, business funding, job support, debt relief, disability assistance, or any other resource or grant. '
      'Also return TRUE if the person is describing a difficult situation (hardship, struggle, crisis) that implies they need help, even if they do not explicitly ask for it. '
      'Return FALSE ONLY for: pure social reactions (hi, thank you, congrats, emojis), event check-ins, announcements, or content with no connection to a personal need or request. '
      'When in doubt, return TRUE. '
      'Content type: ', content_type, '. Text: ', SUBSTR(body, 1, 1500)
    ),
    endpoint     => 'gemini-2.5-flash',
    connection_id => 'bigtribebuilders.eu.manychat',
    model_params  => JSON '{"generation_config": {"thinking_config": {"thinking_budget": 0}}}'
  ).result                  AS is_question,

  CURRENT_TIMESTAMP()       AS classified_at

FROM ${ref("stg_grant_candidates")}

${when(incremental(), `
  WHERE content_id NOT IN (
    SELECT content_id FROM ${self()}
  )
`)}
