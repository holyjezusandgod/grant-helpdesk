config {
  type: "incremental",
  schema: "grant_helpdesk",
  name: "grant_question_classifier",
  uniqueKey: ["content_id"],
  description: "Incremental LLM classification of all member content using AI.GENERATE_BOOL. Flags genuine grant-related questions. Already-classified rows are skipped on each run."
}

SELECT
  content_id,
  content_type,

  AI.GENERATE_BOOL(
    (
      'You are a classifier for a community helpdesk. Your job is to identify any content that needs a staff or community response. '
      'Return TRUE if the content contains ANY of the following: '
      'a question (direct or implied), a request for help or information, a tech issue (broken links, zoom problems, password issues, replay access), '
      'a membership or billing question, a scheduling or event question, a request directed at a named person or moderator, '
      'a complaint or frustration that implies something needs to be resolved, a new member introduction that warrants a welcome response, '
      'or any other content where a reasonable community manager would feel they should reply. '
      'Return FALSE ONLY for: pure social reactions (likes, congrats, emojis-only, short affirmations like "love this" or "thank you"), '
      'general commentary with no ask, or announcements from staff with no question embedded. '
      'When in doubt, return TRUE. '
      'Content type: ', content_type, '. Text: ', SUBSTR(body, 1, 1500)
    ),
    endpoint     => 'gemini-2.5-flash',
    connection_id => 'bigtribebuilders.eu.manychat',
    model_params  => JSON '{"generation_config": {"thinking_config": {"thinking_budget": 0}}}'
  ).result                  AS is_question,

  CURRENT_TIMESTAMP()       AS classified_at

FROM ${ref("stg_grant_candidates")}

${when(incremental(), `
  WHERE content_id NOT IN (
    SELECT content_id FROM ${self()}
  )
`)}
